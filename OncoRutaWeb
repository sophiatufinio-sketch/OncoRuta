<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OncoRuta Mujer Inteligente — INEN</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --rose: #C0185A;
  --rose-l: #F5E6ED;
  --rose-m: #E8A0BC;
  --teal: #0F6E56;
  --teal-l: #E0F2F1;
  --teal-m: #5DCAA5;
  --amber: #854F0B;
  --amber-l: #FFF8E1;
  --purple: #3C3489;
  --purple-l: #EEEDFE;
  --gray: #444441;
  --gray-l: #F1EFE8;
  --gray-m: #888780;
  --white: #FFFFFF;
  --text: #1A1A1A;
  --text-muted: #5F5E5A;
  --border: rgba(0,0,0,0.1);
  --radius: 10px;
  --font-size: 1rem;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Inter', system-ui, sans-serif; background: #F5F4F0; color: var(--text); min-height: 100vh; font-size: var(--font-size); }

/* FONT SIZE CONTROL */
body.font-sm { --font-size: 0.875rem; }
body.font-md { --font-size: 1rem; }
body.font-lg { --font-size: 1.15rem; }
body.font-xl { --font-size: 1.3rem; }

/* ── TOPBAR ── */
.topbar { background: var(--rose); padding: 0 14px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
.topbar-brand { display: flex; align-items: center; gap: 8px; }
.topbar-logo { width: 30px; height: 30px; background: rgba(255,255,255,0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
.topbar-logo svg { width: 16px; height: 16px; fill: white; }
.topbar-name { color: white; font-size: 14px; font-weight: 600; }
.topbar-sub { color: rgba(255,255,255,0.7); font-size: 10px; }
.topbar-right { display: flex; align-items: center; gap: 5px; }

/* Accessibility buttons */
.acc-btn { background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.25); border-radius: 8px; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 13px; transition: background 0.15s; }
.acc-btn:hover, .acc-btn.active { background: rgba(255,255,255,0.3); }
.acc-btn.lang-active { background: white; color: var(--rose); border-color: white; font-weight: 700; font-size: 11px; }
.acc-btn-wa { background: #25D366; color: white; border: none; border-radius: 8px; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; }

/* Font size popup */
.font-popup { position: absolute; top: 58px; right: 14px; background: white; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); padding: 10px; display: none; z-index: 200; min-width: 140px; }
.font-popup.open { display: block; }
.font-popup-title { font-size: 11px; color: var(--text-muted); margin-bottom: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; }
.font-size-btns { display: flex; gap: 6px; }
.font-size-btn { flex: 1; border: 1px solid var(--border); border-radius: 6px; padding: 6px; font-family: inherit; cursor: pointer; background: white; color: var(--text); font-weight: 500; transition: all 0.1s; }
.font-size-btn.active { background: var(--rose-l); border-color: var(--rose); color: var(--rose); }

/* ── NAV BOTTOM ── */
.nav-bottom { background: white; border-top: 0.5px solid var(--border); display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: 100; }
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 10px 0 8px; cursor: pointer; border: none; background: none; color: var(--gray-m); font-size: 9px; font-family: inherit; transition: color 0.15s; position: relative; }
.nav-item.active { color: var(--rose); }
.nav-item svg { width: 21px; height: 21px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
.nav-dot { width: 5px; height: 5px; background: var(--rose); border-radius: 50%; position: absolute; top: 6px; right: calc(50% - 14px); }

/* ── MAIN ── */
.main { padding: 14px 14px 100px; max-width: 480px; margin: 0 auto; }

/* ── SCREENS ── */
.screen { display: none; }
.screen.active { display: block; }

/* ── GREETING ── */
.greeting-card { background: linear-gradient(135deg, var(--rose) 0%, #8B0D3A 100%); border-radius: 16px; padding: 18px; margin-bottom: 14px; color: white; }
.greeting-badge { background: rgba(255,255,255,0.2); border-radius: 20px; padding: 3px 10px; font-size: 11px; display: inline-block; margin-bottom: 6px; }
.greeting-name { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
.greeting-sub { font-size: 13px; opacity: 0.85; line-height: 1.5; }
.greeting-stats { display: flex; gap: 8px; margin-top: 12px; }
.g-stat { background: rgba(255,255,255,0.15); border-radius: 8px; padding: 7px 10px; flex: 1; text-align: center; }
.g-stat-val { font-size: 17px; font-weight: 600; }
.g-stat-lbl { font-size: 9px; opacity: 0.8; margin-top: 1px; }

/* Quick access buttons on home screen */
.quick-access { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 14px; }
.qa-btn { background: white; border: 0.5px solid var(--border); border-radius: 10px; padding: 12px; display: flex; align-items: center; gap: 9px; cursor: pointer; transition: border-color 0.15s; }
.qa-btn:hover { border-color: var(--rose-m); }
.qa-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 16px; }
.qa-icon.cita { background: var(--rose-l); }
.qa-icon.result { background: var(--teal-l); }
.qa-icon.navi { background: var(--purple-l); }
.qa-icon.psi { background: var(--amber-l); }
.qa-label { font-size: 12px; font-weight: 600; color: var(--text); line-height: 1.3; }
.qa-sub { font-size: 10px; color: var(--text-muted); margin-top: 1px; }

/* WhatsApp quick bar */
.wa-quick-bar { background: #25D366; border-radius: 10px; padding: 11px 14px; margin-bottom: 14px; display: flex; align-items: center; gap: 10px; cursor: pointer; }
.wa-quick-bar:hover { opacity: 0.92; }
.wa-quick-icon { font-size: 22px; }
.wa-quick-text { flex: 1; }
.wa-quick-title { color: white; font-size: 13px; font-weight: 600; }
.wa-quick-sub { color: rgba(255,255,255,0.85); font-size: 11px; margin-top: 1px; }
.wa-quick-arrow { color: white; font-size: 16px; }

/* ── PROGRESS RUTA ── */
.section-title { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 8px; }
.ruta-card { background: white; border-radius: var(--radius); border: 0.5px solid var(--border); padding: 14px; margin-bottom: 12px; }
.ruta-steps { display: flex; align-items: center; margin-bottom: 12px; }
.ruta-step { display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 1; position: relative; }
.ruta-step-circle { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; flex-shrink: 0; }
.ruta-step.done .ruta-step-circle { background: var(--teal); color: white; }
.ruta-step.current .ruta-step-circle { background: var(--rose); color: white; box-shadow: 0 0 0 3px rgba(192,24,90,0.2); }
.ruta-step.pending .ruta-step-circle { background: var(--gray-l); color: var(--gray-m); }
.ruta-step-label { font-size: 8px; color: var(--text-muted); text-align: center; line-height: 1.3; }
.ruta-step.current .ruta-step-label { color: var(--rose); font-weight: 600; }
.ruta-line { flex: 1; height: 2px; background: var(--gray-l); margin-bottom: 16px; }
.ruta-line.done { background: var(--teal); }
.ruta-status { background: var(--rose-l); border-radius: 8px; padding: 9px 12px; display: flex; align-items: center; gap: 9px; }
.ruta-status-icon { width: 30px; height: 30px; background: var(--rose); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.ruta-status-icon svg { width: 14px; height: 14px; stroke: white; fill: none; stroke-width: 2; }
.ruta-status-text { font-size: 12px; color: var(--rose); font-weight: 500; line-height: 1.4; }
.ruta-status-sub { font-size: 10px; color: #A0185A; margin-top: 2px; }

/* ── CITA CARD ── */
.cita-card { background: white; border-radius: var(--radius); border: 0.5px solid var(--border); padding: 14px; margin-bottom: 12px; }
.cita-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
.cita-tag { background: var(--amber-l); color: var(--amber); font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 20px; }
.cita-tag.ok { background: var(--teal-l); color: var(--teal); }
.cita-fecha { font-size: 19px; font-weight: 600; }
.cita-dia { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
.cita-info { display: flex; flex-direction: column; gap: 7px; margin-bottom: 12px; }
.cita-row { display: flex; align-items: flex-start; gap: 9px; font-size: 13px; }
.cita-row svg { width: 15px; height: 15px; stroke: var(--gray-m); fill: none; stroke-width: 1.5; flex-shrink: 0; margin-top: 1px; }
.cita-row-text { color: var(--text); line-height: 1.4; }
.cita-llevar { background: var(--gray-l); border-radius: 8px; padding: 9px 12px; margin-bottom: 12px; }
.cita-llevar-title { font-size: 10px; font-weight: 600; color: var(--gray); text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 5px; }
.cita-llevar-item { font-size: 12px; color: var(--text-muted); display: flex; align-items: center; gap: 6px; margin-bottom: 3px; }
.cita-llevar-item::before { content: "•"; color: var(--rose); font-weight: 700; }
.btn-primary { background: var(--rose); color: white; border: none; border-radius: 10px; padding: 12px; font-size: 14px; font-weight: 600; width: 100%; cursor: pointer; font-family: inherit; transition: opacity 0.15s; }
.btn-primary:hover { opacity: 0.9; }
.btn-secondary { background: white; color: var(--rose); border: 1.5px solid var(--rose); border-radius: 10px; padding: 10px; font-size: 13px; font-weight: 500; width: 100%; cursor: pointer; font-family: inherit; margin-top: 7px; }

/* ── RESULTADO ── */
.result-card { background: white; border-radius: var(--radius); border: 0.5px solid var(--border); padding: 14px; margin-bottom: 12px; }
.result-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.result-icon { width: 38px; height: 38px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.result-icon.lab { background: var(--purple-l); }
.result-icon.lab svg { stroke: var(--purple); }
.result-icon.img { background: var(--teal-l); }
.result-icon.img svg { stroke: var(--teal); }
.result-icon svg { width: 19px; height: 19px; fill: none; stroke-width: 1.8; }
.result-title { font-size: 14px; font-weight: 600; }
.result-date { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.result-explanation { background: var(--teal-l); border-radius: 8px; padding: 11px; margin-bottom: 10px; }
.result-exp-label { font-size: 10px; font-weight: 600; color: var(--teal); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
.result-exp-text { font-size: 12px; color: #004D40; line-height: 1.6; }
.result-action { font-size: 12px; color: var(--text-muted); line-height: 1.5; margin-bottom: 10px; }
.result-action strong { color: var(--rose); }
.btn-download { background: var(--gray-l); color: var(--gray); border: none; border-radius: 8px; padding: 9px 12px; font-size: 12px; font-weight: 500; display: flex; align-items: center; gap: 7px; cursor: pointer; font-family: inherit; width: 100%; }
.btn-download svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.5; }

/* ── ALERTAS ── */
.alerta-card { border-radius: var(--radius); border: 0.5px solid var(--border); padding: 12px 14px; margin-bottom: 8px; display: flex; gap: 10px; align-items: flex-start; background: white; }
.alerta-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
.alerta-dot.urgente { background: #E24B4A; }
.alerta-dot.info { background: var(--amber); }
.alerta-dot.ok { background: var(--teal); }
.alerta-body-title { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
.alerta-body-text { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
.alerta-time { font-size: 10px; color: var(--text-muted); margin-top: 4px; }

/* ── NAVEGADOR CARD (vista paciente) ── */
.nav-card { background: var(--purple-l); border-radius: var(--radius); padding: 14px; margin-bottom: 12px; border: 0.5px solid rgba(83,74,183,0.2); }
.nav-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.nav-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--purple); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 13px; flex-shrink: 0; }
.nav-name { font-size: 14px; font-weight: 600; color: var(--purple); }
.nav-role { font-size: 11px; color: #534AB7; }
.nav-message { font-size: 12px; color: var(--purple); line-height: 1.6; margin-bottom: 10px; }
.btn-nav { background: var(--purple); color: white; border: none; border-radius: 8px; padding: 10px 14px; font-size: 13px; font-weight: 500; width: 100%; cursor: pointer; font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 7px; }
.btn-nav svg { width: 14px; height: 14px; stroke: white; fill: none; stroke-width: 2; }

/* ── WHATSAPP MOCK ── */
.wa-container { background: #E8DCCF; border-radius: var(--radius); padding: 12px; margin-bottom: 12px; }
.wa-header { background: #0F6E56; padding: 9px 12px; display: flex; align-items: center; gap: 8px; margin: -12px -12px 12px; border-radius: var(--radius) var(--radius) 0 0; }
.wa-header-avatar { width: 30px; height: 30px; background: rgba(255,255,255,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; }
.wa-header-name { color: white; font-size: 13px; font-weight: 600; }
.wa-header-status { color: rgba(255,255,255,0.7); font-size: 10px; }
.wa-bubble { max-width: 85%; padding: 8px 10px; border-radius: 10px; margin-bottom: 7px; font-size: 12px; line-height: 1.5; }
.wa-bubble.bot { background: white; border-radius: 2px 10px 10px 10px; }
.wa-bubble.user { background: #D9FDD3; border-radius: 10px 2px 10px 10px; margin-left: auto; }
.wa-time { font-size: 9px; color: var(--gray-m); text-align: right; margin-top: 3px; }
.wa-menu { background: white; border-radius: 10px; padding: 8px 10px; margin-bottom: 7px; }
.wa-menu-item { font-size: 12px; color: #0F6E56; padding: 5px 0; cursor: pointer; display: flex; align-items: center; gap: 7px; border-bottom: 0.5px solid rgba(0,0,0,0.06); }
.wa-menu-item:last-child { border-bottom: none; }
.wa-menu-item::before { content: attr(data-n); font-weight: 700; color: var(--gray-m); font-size: 11px; width: 14px; }

/* ── PANEL NAVEGADOR (staff) ── */
.panel-header { background: var(--purple); border-radius: 12px; padding: 14px; margin-bottom: 12px; color: white; }
.panel-h-title { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
.panel-h-sub { font-size: 11px; opacity: 0.8; }
.panel-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 7px; margin-bottom: 12px; }
.p-stat { background: white; border-radius: 8px; padding: 9px; text-align: center; border: 0.5px solid var(--border); }
.p-stat-val { font-size: 19px; font-weight: 600; }
.p-stat-lbl { font-size: 9px; color: var(--text-muted); margin-top: 2px; }
.p-stat-val.green { color: #3B6D11; }
.p-stat-val.amber { color: var(--amber); }
.p-stat-val.red { color: #A32D2D; }
.paciente-item { background: white; border-radius: var(--radius); border: 0.5px solid var(--border); padding: 10px 12px; margin-bottom: 7px; display: flex; align-items: center; gap: 10px; cursor: pointer; }
.paciente-item:hover { border-color: var(--purple); }
.sem-dot { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }
.sem-dot.verde { background: #3B6D11; }
.sem-dot.amarillo { background: var(--amber); box-shadow: 0 0 0 3px rgba(133,79,11,0.15); }
.sem-dot.rojo { background: #A32D2D; box-shadow: 0 0 0 3px rgba(163,45,45,0.15); }
.pac-avatar { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; flex-shrink: 0; }
.pac-avatar.a { background: var(--rose-l); color: var(--rose); }
.pac-avatar.b { background: var(--amber-l); color: var(--amber); }
.pac-avatar.c { background: var(--purple-l); color: var(--purple); }
.pac-info { flex: 1; min-width: 0; }
.pac-name { font-size: 13px; font-weight: 600; margin-bottom: 1px; }
.pac-detail { font-size: 10px; color: var(--text-muted); }
.pac-action { display: flex; gap: 5px; }
.pac-btn { border: none; border-radius: 6px; padding: 5px 7px; font-size: 11px; cursor: pointer; font-family: inherit; font-weight: 500; }
.pac-btn.call { background: var(--teal-l); color: var(--teal); }
.pac-btn.msg { background: var(--purple-l); color: var(--purple); }
.pac-btn.alert { background: #FFEBEE; color: #7F0000; }
.pac-btn.hc { background: var(--rose-l); color: var(--rose); }
.filtros { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 10px; }
.filtro-btn { background: white; border: 0.5px solid var(--border); border-radius: 20px; padding: 4px 11px; font-size: 11px; cursor: pointer; font-family: inherit; color: var(--text-muted); }
.filtro-btn.active { background: var(--purple-l); color: var(--purple); border-color: rgba(83,74,183,0.3); font-weight: 600; }

/* ── JORNADA NAVEGADOR ── */
.jornada-item { background: white; border-radius: var(--radius); border: 0.5px solid var(--border); padding: 12px 14px; margin-bottom: 8px; }
.jornada-time { font-size: 11px; font-weight: 700; color: var(--purple); margin-bottom: 4px; }
.jornada-title { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 5px; }
.jornada-desc { font-size: 12px; color: var(--text-muted); line-height: 1.5; margin-bottom: 4px; }
.jornada-tool { font-size: 11px; color: var(--teal); background: var(--teal-l); border-radius: 5px; padding: 3px 8px; display: inline-block; }
.impact-box { background: var(--teal-l); border: 0.5px solid rgba(15,110,86,0.25); border-radius: 10px; padding: 12px 14px; margin-top: 14px; }
.impact-box-title { font-size: 12px; font-weight: 600; color: var(--teal); margin-bottom: 5px; }
.impact-box-text { font-size: 12px; color: #004D40; line-height: 1.6; }

/* ── HISTORIA CLINICA ── */
.hc-section { background: white; border-radius: var(--radius); border: 0.5px solid var(--border); padding: 14px; margin-bottom: 12px; }
.hc-section-title { font-size: 12px; font-weight: 700; color: var(--text); border-bottom: 1px solid var(--gray-l); padding-bottom: 7px; margin-bottom: 10px; display: flex; align-items: center; gap: 7px; }
.hc-section-title svg { width: 15px; height: 15px; stroke: var(--rose); fill: none; stroke-width: 1.8; }
.hc-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 5px 0; border-bottom: 0.5px solid #f0f0f0; font-size: 12px; gap: 10px; }
.hc-row:last-child { border-bottom: none; }
.hc-label { color: var(--text-muted); flex-shrink: 0; width: 110px; }
.hc-value { color: var(--text); font-weight: 500; text-align: right; flex: 1; }
.ref-item { background: var(--gray-l); border-radius: 8px; padding: 9px 11px; margin-bottom: 7px; }
.ref-item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 3px; }
.ref-item-title { font-size: 12px; font-weight: 600; }
.ref-item-tag { font-size: 10px; padding: 2px 7px; border-radius: 10px; font-weight: 600; }
.ref-item-tag.origen { background: var(--teal-l); color: var(--teal); }
.ref-item-tag.interna { background: var(--purple-l); color: var(--purple); }
.ref-item-date { font-size: 11px; color: var(--text-muted); }
.ref-item-desc { font-size: 11px; color: var(--text-muted); margin-top: 3px; line-height: 1.4; }
.atencion-item { border-left: 3px solid var(--rose); padding: 8px 11px; margin-bottom: 8px; background: white; border-radius: 0 8px 8px 0; }
.atencion-fecha { font-size: 10px; color: var(--gray-m); margin-bottom: 2px; }
.atencion-titulo { font-size: 12px; font-weight: 600; margin-bottom: 2px; }
.atencion-medico { font-size: 11px; color: var(--text-muted); }
.atencion-nota { font-size: 11px; color: var(--text-muted); margin-top: 4px; font-style: italic; line-height: 1.4; }

/* ── PSICOLOGIA ── */
.psi-card { background: var(--amber-l); border: 0.5px solid rgba(133,79,11,0.2); border-radius: var(--radius); padding: 14px; margin-bottom: 12px; }
.psi-header { display: flex; align-items: center; gap: 9px; margin-bottom: 8px; }
.psi-icon { width: 36px; height: 36px; background: var(--amber); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 17px; }
