function t(key) { return (i18n[lang] && i18n[lang][key]) ? i18n[lang][key] : (i18n['es'][key] || key); }

function setLang(l) {
  lang = l;
  document.getElementById('btn-es').classList.toggle('lang-active', l === 'es');
  document.getElementById('btn-qu').classList.toggle('lang-active', l === 'qu');
  applyTranslations();
  showToast(l === 'qu' ? 'Quechua simipi rikuchikunña ✓' : 'Idioma cambiado a Español ✓');
}

function applyTranslations() {
  var ids = ['gs-citas','gs-siguiente','gs-examenes','t-mi-ruta',
    't-proxima-cita','t-citas-prev','t-resultados','t-notificaciones','t-canal-sms',
    't-llevar','llevar-1','llevar-2','llevar-3','llevar-4',
    't-que-significa','t-que-significa2','res1-exp','res2-exp','t-descargar',
    'al1-title','al1-text','al2-title','al2-text','al3-title','al3-text',
    'wa-status','btn-nav-text','cita-fecha','cita-dia','cita-medico',
    'res1-title','res1-date','res2-title','res2-date','res1-action',
    'lang-banner-text','greeting-badge'];
  ids.forEach(function(id) {
    var el = document.getElementById(id);
    if (el) { var v = t(id); if (v) el.textContent = v; }
  });
  document.getElementById('greeting-name').textContent = 'Hola, María 👋';
  var sub = t('greeting-sub-maria');
  document.getElementById('greeting-sub').innerHTML = sub.replace('Evaluación médica', '<strong style="color:white">Evaluación médica</strong>');
  document.getElementById('nav-message').textContent = t('nav-message-maria');
  buildRutaSteps(1);
  document.getElementById('ruta-status-text').textContent = t('ruta-status-maria');
  document.getElementById('ruta-status-sub').textContent = t('ruta-status-sub-maria');
  var lb = document.getElementById('lang-banner');
  if (lb) lb.style.display = (lang === 'es') ? 'flex' : 'none';
  resetWA();
}

function buildRutaSteps(currentStep) {
  var labels = t('ruta-step-labels');
  if (!Array.isArray(labels)) labels = ['Admisión','Evaluación','Exámenes','Diagnóstico','Tratamiento'];
  var html = '';
  for (var i = 0; i < labels.length; i++) {
    var cls = i < currentStep ? 'done' : (i === currentStep ? 'current' : 'pending');
    var icon = i < currentStep ? '✓' : (i + 1);
    html += '<div class="ruta-step ' + cls + '"><div class="ruta-step-circle">' + icon + '</div><div class="ruta-step-label">' + labels[i] + '</div></div>';
    if (i < labels.length - 1) html += '<div class="ruta-line' + (i < currentStep ? ' done' : '') + '"></div>';
  }
  document.getElementById('ruta-steps').innerHTML = html;
}

function goScreen(name) {
  document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
  document.querySelectorAll('.nav-item').forEach(function(n) { n.classList.remove('active'); });
  var sc = document.getElementById('screen-' + name);
  if (sc) sc.classList.add('active');
  var ni = document.getElementById('nav-' + name);
  if (ni) ni.classList.add('active');
  else { document.getElementById('nav-inicio') && document.getElementById('nav-inicio').classList.remove('active'); }
  window.scrollTo(0, 0);
}

function showTab(tabId, btn) {
  var container = btn ? btn.closest('.tab-bar') : null;
  if (container) {
    container.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    var parent = container.parentElement;
    parent.querySelectorAll('.tab-content').forEach(function(tc) { tc.classList.remove('active'); });
  } else {
    document.querySelectorAll('.tab-content').forEach(function(tc) { tc.classList.remove('active'); });
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  }
  var el = document.getElementById(tabId);
  if (el) el.classList.add('active');
}


var waReplied = false;
function waReply(n) {
  if (waReplied) return;
  waReplied = true;
  var chat = document.getElementById('wa-chat');
  var opts = [t('wa-opt-1'), t('wa-opt-2'), t('wa-opt-3'), t('wa-opt-4')];
  var reps = [t('wa-r1'), t('wa-r2'), t('wa-r3'), t('wa-r4')];
  var userBubble = document.createElement('div');
  userBubble.className = 'wa-bubble user';
  userBubble.innerHTML = n + '. ' + opts[n-1] + '<div class="wa-time">Ahora ✓✓</div>';
  chat.appendChild(userBubble);
  setTimeout(function() {
    var botBubble = document.createElement('div');
    botBubble.className = 'wa-bubble bot';
    botBubble.innerHTML = reps[n-1] + '<div class="wa-time">Ahora ✓✓</div>';
    chat.appendChild(botBubble);
    botBubble.scrollIntoView({ behavior: 'smooth' });
  }, 800);
}

function resetWA() {
  waReplied = false;
  var chat = document.getElementById('wa-chat');
  var menu = '<div class="wa-menu">'
    + '<div class="wa-menu-item" data-n="1" onclick="waReply(1)">' + t('wa-opt-1') + '</div>'
    + '<div class="wa-menu-item" data-n="2" onclick="waReply(2)">' + t('wa-opt-2') + '</div>'
    + '<div class="wa-menu-item" data-n="3" onclick="waReply(3)">' + t('wa-opt-3') + '</div>'
    + '<div class="wa-menu-item" data-n="4" onclick="waReply(4)">' + t('wa-opt-4') + '</div>'
    + '</div>';
  chat.innerHTML = '<div class="wa-bubble bot">' + t('wa-msg1') + menu + '<div class="wa-time">8:00 ✓✓</div></div>';
}

function filtrar(btn, tipo) {
  document.querySelectorAll('.filtro-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  var msgs = { 'riesgo': 'Mostrando 7 pacientes en riesgo', 'quechua': 'Mostrando 9 pacientes Quechua', 'provincia': 'Mostrando 14 pacientes de provincia', 'todas': 'Mostrando 25 pacientes' };
  showToast(msgs[tipo] || 'Filtrando...');
}

function toggleFontPopup() {
  document.getElementById('font-popup').classList.toggle('open');
}

function setFont(size) {
  document.body.className = 'font-' + size;
  document.querySelectorAll('.font-size-btn').forEach(function(b) { b.classList.remove('active'); });
  var el = document.getElementById('fs-' + size);
  if (el) el.classList.add('active');
  document.getElementById('font-popup').classList.remove('open');
  showToast('Tamaño de letra ajustado');
}

function toggleAudio() {
  audioOn = !audioOn;
  var btn = document.getElementById('btn-audio');
  btn.style.background = audioOn ? 'rgba(255,255,255,0.4)' : 'rgba(255,255,255,0.15)';
  if (audioOn && window.speechSynthesis) {
    var msg = new SpeechSynthesisUtterance('OncoRuta INEN. Plataforma de navegación oncológica. Bienvenida.');
    msg.lang = lang === 'qu' ? 'es-PE' : 'es-PE';
    window.speechSynthesis.speak(msg);
    showToast('🔊 Audio activado');
  } else {
    window.speechSynthesis && window.speechSynthesis.cancel();
    showToast('🔇 Audio desactivado');
  }
}

// Close font popup on outside click
document.addEventListener('click', function(e) {
  if (!e.target.closest('#btn-font') && !e.target.closest('#font-popup')) {
    document.getElementById('font-popup').classList.remove('open');
  }
});

var toastTimer;
function showToast(msg) {
  var el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function() { el.classList.remove('show'); }, 2200);
}

applyTranslations();
</script>
